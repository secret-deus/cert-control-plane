# ============================================================
# cert-agent 环境变量配置
# 复制此文件到 /etc/cert-agent/agent.env 并填入实际值
# ============================================================

# 控制面板地址 (必填)
CERT_AGENT_CP_URL=https://cp.example.com

# Agent 名称 (必填)
CERT_AGENT_NAME=web-node-01

# 已知 agent_token 时可预先写入；否则首次启动会自动注册并等待管理员审批
# CERT_AGENT_TOKEN=

# 证书检查表，JSON 数组；每个元素至少包含 local_path
# 例如: [{"local_path":"/etc/nginx/certs/api.crt"},{"local_path":"/etc/nginx/certs/web.crt"}]
# CERT_AGENT_CERT_TABLE=[]

# Agent 本地状态目录 (默认: /var/lib/cert-agent)
# CERT_AGENT_STATE_DIR=/var/lib/cert-agent

# nginx 证书目录 (默认: /etc/nginx/certs)
# CERT_AGENT_NGINX_CERT_DIR=/etc/nginx/certs

# nginx 重载命令 (默认: nginx -s reload)
# CERT_AGENT_NGINX_RELOAD_CMD=nginx -s reload

# 心跳间隔秒数 (默认: 30)
# CERT_AGENT_HEARTBEAT_INTERVAL=30

# 审批轮询间隔秒数 (默认: 5)
# CERT_AGENT_POLL_INTERVAL=5
