# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/certcp

# Fernet key used to encrypt uploaded private keys in the database
CA_KEY_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Admin API key for Control API
ADMIN_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# CORS allowed origins (JSON array; default: [] — must be set for frontend access)
# Example: CORS_ORIGINS=["https://your-domain.com","https://admin.example.com"]
# CORS_ORIGINS=["https://your-domain.com"]

# Local development mode
# DEV_MODE=false

# Docker PostgreSQL password (override in production!)
# POSTGRES_PASSWORD=change-me-in-production

# Rollout orchestrator
ROLLOUT_INTERVAL_SECONDS=30
DEFAULT_BATCH_SIZE=10
ROLLOUT_ITEM_TIMEOUT_MINUTES=10
