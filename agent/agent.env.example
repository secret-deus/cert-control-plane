# ============================================================
# cert-agent 环境变量配置
# 复制此文件到 /etc/cert-agent/agent.env 并填入实际值
# ============================================================

# 控制面板地址 (必填)
CERT_AGENT_CP_URL=https://cp.example.com:8443

# CA 证书路径，用于验证控制面板的 TLS 证书 (必填)
CERT_AGENT_CA_CERT=/etc/cert-agent/ca.crt

# Agent 名称，必须与控制面板中预注册的名称一致 (必填)
CERT_AGENT_NAME=web-node-01

# 首次注册令牌，注册完成后可删除 (首次运行必填)
CERT_AGENT_BOOTSTRAP_TOKEN=

# Agent 本地状态目录 (默认: /var/lib/cert-agent)
# CERT_AGENT_STATE_DIR=/var/lib/cert-agent

# nginx 证书目录 (默认: /etc/nginx/certs)
# CERT_AGENT_NGINX_CERT_DIR=/etc/nginx/certs

# nginx 重载命令 (默认: nginx -s reload)
# CERT_AGENT_NGINX_RELOAD_CMD=nginx -s reload

# 心跳间隔秒数 (默认: 30)
# CERT_AGENT_HEARTBEAT_INTERVAL=30

# 证书过期前 N 天主动续期 (默认: 7)
# CERT_AGENT_RENEW_BEFORE_DAYS=7

# 连续 mTLS 认证失败 N 次后尝试重新注册 (默认: 3)
# CERT_AGENT_MAX_AUTH_FAILURES=3
